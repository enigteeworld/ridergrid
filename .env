# ============================================
# DISPATCH NG - Environment Configuration
# ============================================
# Copy this file to .env.local and fill in your values

# --------------------------------------------
# Supabase Configuration (Required)
# --------------------------------------------
# Get these from your Supabase project dashboard
# Project Settings > API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# --------------------------------------------
# Payment Provider Configuration (Required)
# --------------------------------------------
# Paystack (Recommended for Nigeria)
VITE_PAYSTACK_PUBLIC_KEY=pk_test_your_paystack_key
VITE_PAYSTACK_SECRET_KEY=sk_test_your_paystack_secret

# OR Flutterwave (Alternative)
# VITE_FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_TEST-your-key

# --------------------------------------------
# Platform Configuration
# --------------------------------------------
# Your platform fee per delivery (in Naira)
VITE_PLATFORM_FEE=200

# Minimum wallet funding amount
VITE_MIN_WALLET_FUNDING=500

# Maximum single transaction amount
VITE_MAX_TRANSACTION_AMOUNT=500000

# --------------------------------------------
# Application Settings
# --------------------------------------------
# App name displayed throughout
VITE_APP_NAME=Dispatch NG

# App URL (for redirects)
VITE_APP_URL=http://localhost:5173

# Support contact
VITE_SUPPORT_EMAIL=support@dispatchng.com
VITE_SUPPORT_PHONE=+2348000000000

# --------------------------------------------
# Feature Flags
# --------------------------------------------
# Enable/disable KYC requirement for customers
VITE_REQUIRE_CUSTOMER_KYC=false

# Enable/disable KYC requirement for riders
VITE_REQUIRE_RIDER_KYC=true

# Auto-complete delivery after hours (if no dispute)
VITE_AUTO_COMPLETE_HOURS=24

# Enable OTP confirmation for deliveries
VITE_ENABLE_DELIVERY_OTP=true

# --------------------------------------------
# Admin Configuration
# --------------------------------------------
# Admin email(s) - comma separated
VITE_ADMIN_EMAILS=admin@dispatchng.com

# --------------------------------------------
# Optional: Third Party Services
# --------------------------------------------
# Google Maps API (for geocoding and maps)
# VITE_GOOGLE_MAPS_API_KEY=your-google-maps-key

# Cloudinary (for image uploads)
# VITE_CLOUDINARY_CLOUD_NAME=your-cloud-name
# VITE_CLOUDINARY_UPLOAD_PRESET=your-upload-preset

# --------------------------------------------
# Optional: Analytics
# --------------------------------------------
# VITE_GOOGLE_ANALYTICS_ID=GA-XXXXXXXX
